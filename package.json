{
  "name": "@quickdesign/cli",
  "version": "0.7.0",
  "description": "QuickDesign CLI — image + video generation (Sora 2, Kling, Seedance 2.0, UGC), Smart Ad Creator (incl. Advantage+), Spy Brands ad intelligence, Brand DNA extraction, and designs CRUD — from your terminal or a Claude Code agent.",
  "keywords": [
    "quickdesign",
    "cli",
    "ai",
    "image-generation",
    "video-generation",
    "spy-brands",
    "meta-ad-library",
    "claude-code"
  ],
  "license": "MIT",
  "author": "QuickDesign",
  "homepage": "https://quickdesign.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/ottasilver/quickdesign-cli.git"
  },
  "bugs": {
    "url": "https://github.com/ottasilver/quickdesign-cli/issues"
  },
  "type": "module",
  "bin": {
    "quickdesign": "./dist/bin.js"
  },
  "files": [
    "dist",
    "skills",
    ".claude-plugin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "stamp-skill-version": "node -e \"require('fs').writeFileSync('skills/quickdesign/.version', require('./package.json').version + '\\n')\"",
    "stamp-plugin-version": "node -e \"const fs=require('fs');const v=require('./package.json').version;const m=require('./.claude-plugin/plugin.json');m.version=v;fs.writeFileSync('.claude-plugin/plugin.json',JSON.stringify(m,null,2)+'\\n')\"",
    "build": "npm run stamp-skill-version && npm run stamp-plugin-version && tsc && chmod +x dist/bin.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "lint": "echo \"(lint not configured)\"",
    "link:local": "npm run build && npm link",
    "unlink:local": "npm unlink -g @quickdesign/cli"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "kleur": "^4.1.5",
    "open": "^10.1.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0"
  }
}
